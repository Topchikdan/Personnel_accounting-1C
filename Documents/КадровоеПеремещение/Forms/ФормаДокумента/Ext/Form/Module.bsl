
&НаКлиенте
Процедура СотрудникПриИзменении(Элемент)
	СотрудникПриИзмененииНаСервере();
КонецПроцедуры

&НаСервере
Процедура СотрудникПриИзмененииНаСервере()
	
	ДанныеСотрудника = РегистрыСведений.КадроваяИстория.ПолучитьПоследнее(
		Объект.ДатаПеремещения,
		Новый Структура("Сотрудник", Объект.Сотрудник)
	);
	
	Объект.СтарыйОтдел     = ДанныеСотрудника.Отдел;
	Объект.СтараяДолжность = ДанныеСотрудника.Должность;	
КонецПроцедуры
