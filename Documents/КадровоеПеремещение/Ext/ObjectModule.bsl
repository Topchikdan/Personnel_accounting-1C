Процедура ОбработкаПроведения(Отказ, РежимПроведения)
// Проверка 1: дата перемещения не меньше даты документа
	Если ЗначениеЗаполнено(ДатаПеремещения) И ДатаПеремещения < НачалоДня(Дата) Тогда
		Сообщить("Ошибка: дата перемещения не может быть меньше даты документа!", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Проверка 2: новая должность действующая
	Если НоваяДолжность.Действующая = Ложь Тогда
		Сообщить("Ошибка: должность является недействующей!", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Проверка 3: сотрудник принят и не уволен
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КадроваяИстория.Должность
		|ИЗ
		|	РегистрСведений.КадроваяИстория.СрезПоследних(
		|		&Дата,
		|	) КАК КадроваяИстория
		|ГДЕ
		|	КадроваяИстория.Сотрудник = &Сотрудник
		|	И КадроваяИстория.Должность <> ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
		|	И КадроваяИстория.Уволен = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Дата", ДатаПеремещения);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	Если Запрос.Выполнить().Пустой() Тогда
		Сообщить("Ошибка: сотрудник не найден или уволен. Перемещение невозможно!", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Получаем текущие данные для записи в движение
	ДанныеСотрудника = РегистрыСведений.КадроваяИстория.ПолучитьПоследнее(
		ДатаПеремещения,
		Новый Структура("Сотрудник", Сотрудник)
	);
	
	
	Движения.КадроваяИстория.Записывать = Истина;
	
	Движение = Движения.КадроваяИстория.Добавить();
	Движение.Период    = ДатаПеремещения;
	Движение.Сотрудник = Сотрудник;
	Движение.Отдел     = НовыйОтдел;
	Движение.Должность = НоваяДолжность;
	Движение.Оклад     = НовыйОклад;
	Движение.Уволен    = Ложь;
	
КонецПроцедуры
