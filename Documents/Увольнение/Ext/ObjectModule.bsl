Процедура ОбработкаПроведения(Отказ, РежимПроведения)
	
	// Проверка 1: дата увольнения не меньше даты документа
	Если ЗначениеЗаполнено(ДатаУвольнения) И ДатаУвольнения < НачалоДня(Дата) Тогда
		Сообщить("Ошибка: дата увольнения не может быть меньше даты документа!", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Проверка 2: сотрудник принят и не уволен
	Запрос = Новый Запрос;
	Запрос.Текст =
		"ВЫБРАТЬ ПЕРВЫЕ 1
		|	КадроваяИстория.Должность,
		|	КадроваяИстория.Отдел,
		|	КадроваяИстория.Оклад
		|ИЗ
		|	РегистрСведений.КадроваяИстория.СрезПоследних(
		|		&Дата,
		|	) КАК КадроваяИстория
		|ГДЕ
		|	КадроваяИстория.Сотрудник = &Сотрудник
		|	И КадроваяИстория.Должность <> ЗНАЧЕНИЕ(Справочник.Должности.ПустаяСсылка)
		|	И КадроваяИстория.Уволен = ЛОЖЬ";
	
	Запрос.УстановитьПараметр("Дата", ДатаУвольнения);
	Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
	
	РезультатЗапроса = Запрос.Выполнить();
	
	Если РезультатЗапроса.Пустой() Тогда
		Сообщить("Ошибка: сотрудник не найден или уже уволен!", СтатусСообщения.Важное);
		Отказ = Истина;
		Возврат;
	КонецЕсли;
	
	// Получаем данные из запроса для записи в движение
	ВыборкаДанных = РезультатЗапроса.Выбрать();
	ВыборкаДанных.Следующий();
	
	
	// Записываем движение
	Движения.КадроваяИстория.Записывать = Истина;
	
	Движение = Движения.КадроваяИстория.Добавить();
	Движение.Период    = ДатаУвольнения;
	Движение.Сотрудник = Сотрудник;
	Движение.Отдел     = ВыборкаДанных.Отдел;
	Движение.Должность = ВыборкаДанных.Должность;
	Движение.Оклад     = ВыборкаДанных.Оклад;
	Движение.Уволен    = Истина;
	
КонецПроцедуры