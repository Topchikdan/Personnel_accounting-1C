Процедура ОбработкаПроведения(Отказ, РежимПроведения)
    
    // Проверка 1: дата приёма не меньше даты документа
    Если ЗначениеЗаполнено(ДатаПриема) И ДатаПриема < НачалоДня(Дата) Тогда
        Сообщить("Ошибка: дата приёма не может быть меньше даты документа!", СтатусСообщения.Важное);
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Проверка 2: должность действующая
    Если Должность.Действующая = Ложь Тогда
        Сообщить("Ошибка: должность является недействующей!", СтатусСообщения.Важное);
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Проверка 3: ищем любую запись о приёме этого сотрудника 
    Запрос = Новый Запрос;
    Запрос.Текст =
        "ВЫБРАТЬ ПЕРВЫЕ 1
        |    КадроваяИстория.Регистратор
        |ИЗ
        |    РегистрСведений.КадроваяИстория КАК КадроваяИстория
        |ГДЕ
        |    КадроваяИстория.Сотрудник = &Сотрудник
        |    И КадроваяИстория.Уволен = ЛОЖЬ
        |    И КадроваяИстория.Регистратор <> &ТекущийДокумент";
    
    Запрос.УстановитьПараметр("Сотрудник", Сотрудник);
    Запрос.УстановитьПараметр("ТекущийДокумент", Ссылка);
    
    Если НЕ Запрос.Выполнить().Пустой() Тогда
        Сообщить("Ошибка: сотрудник уже принят на работу!", СтатусСообщения.Важное);
        Отказ = Истина;
        Возврат;
    КонецЕсли;
    
    // Записываем движение
    Движения.КадроваяИстория.Записывать = Истина;
    
    Движение = Движения.КадроваяИстория.Добавить();
    Движение.Период    = ДатаПриема;
    Движение.Сотрудник = Сотрудник;
    Движение.Отдел     = Отдел;
    Движение.Должность = Должность;
    Движение.Оклад     = Оклад;
    Движение.Уволен    = Ложь;
    
КонецПроцедуры